{
  "name": "@tunnckocore/pi-gpt-fast-mode",
  "version": "0.1.1",
  "description": "A super basic Pi extension that toggles GPT-5.5 Codex Fast mode with /fast (the default 'priority'), nothing else - one file, 180 lines of code.",
  "type": "module",
  "module": "src/index.ts",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/tunnckoCore/pi-gpt-fastmode.git"
  },
  "keywords": [
    "pi-package",
    "pi-extension",
    "gpt-5.5",
    "codex",
    "fast-mode"
  ],
  "pi": {
    "extensions": [
      "./src/index.ts"
    ]
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "test": "bun test ./test/index.ts",
    "typecheck": "tsc --noEmit"
  },
  "peerDependencies": {
    "@earendil-works/pi-coding-agent": "*"
  },
  "devDependencies": {
    "@earendil-works/pi-coding-agent": "^0.80.3",
    "@types/bun": "latest",
    "typescript": "^6"
  },
  "files": [
    "src"
  ]
}
